# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Gmail that SENDS the digest (needs an App Password, not your real password)
SENDER_EMAIL=your_sender@gmail.com
SENDER_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Emails that RECEIVE the digest (comma-separated for multiple)
RECIPIENT_EMAILS=recipient1@gmail.com,recipient2@gmail.com
